# BME Services — Apache: našumas (cache/compress/webp) + saugumo antraštės
Options -Indexes
ServerSignature Off
AddDefaultCharset UTF-8

# ---------- MIME ----------
AddType video/mp4 .mp4
AddType video/webm .webm
AddType image/webp .webp
AddType application/manifest+json .webmanifest

# ---------- WebP negotiation (serve .webp jei naršyklė palaiko ir failas yra) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # ---------- 301: pensionuoti URL (pump-repair -> propulsion-marine) ----------
  RewriteRule ^services/pump-repair/?$ /services/propulsion-marine/ [R=301,L]

  # ---------- WebP negotiation (serve .webp jei naršyklė palaiko ir failas yra) ----------
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} (.+)\.(jpe?g|png)$
  RewriteCond %1.webp -f
  RewriteRule (.+)\.(jpe?g|png)$ $1.webp [T=image/webp,E=webp:1,L]
</IfModule>

# ---------- Saugumo antraštės ----------
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  # CSP: leidžiam INLINE CSS/JS (Claude Design) + Google Fonts + savus video/paveikslus
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; media-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests"
  Header set Accept-Ranges bytes
  Header append Vary Accept env=webp
</IfModule>

# ---------- Cache ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|webp|ico|svg|mp4|webm|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/manifest+json text/plain application/xml
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# ---------- Paslėptų failų apsauga ----------
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
